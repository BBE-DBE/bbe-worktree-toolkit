# WORKTREE_LAYOUT — convention for parallel-track checkouts.
# Generated by bbe-worktree-toolkit v{{TOOLKIT_VERSION}} at {{INSTALL_TIMESTAMP}}.
#
# Read by:
#   {{LAYOUT_DIR}}/scripts/worktree-setup.sh    (create / list / remove)
#   {{LAYOUT_DIR}}/scripts/worktree-cleanup.sh  (stale-worktree + stash GC)
#   {{LAYOUT_DIR}}/scripts/worktree-status.sh   (read-only summary)
#
# Backwards compatibility: when this file is absent, the scripts fall
# back to single-tree mode (each agent shares one working directory).
# Multi-worktree mode is opt-in.

_toolkit_version: "{{TOOLKIT_VERSION}}"
_repo_name: "{{REPO_NAME}}"

# Where new worktrees are created. Relative paths are resolved from
# the repository root.
base_path: "{{BASE_PATH}}"

# Path pattern for individual worktrees. Available substitutions:
#   {track}    e.g. "track_a"
#   {task_id}  e.g. "T-001"
pattern: "{track}-{task_id}"

# Live runtime state — lives OUTSIDE every worktree so all parallel
# checkouts read the same truth. Optional; consumers (e.g. bbe-coord's
# agent-relay) read this when the layout file declares it. Empty
# string disables the feature; scripts then fall back to per-worktree
# state files.
central_state_dir: "{{CENTRAL_STATE_DIR}}"
central_state_file: "SPRINT_STATE.json"

# Optional inbox directory for inter-agent messages. Same opt-in
# semantics as central_state_dir.
central_inbox_path: "{{CENTRAL_STATE_DIR}}/agent_inbox"

# Files that remain isolated per worktree. Listed for documentation;
# git already isolates them naturally — every worktree has its own
# checkout.
isolation_globs:
  - "scripts/**"
  - "tests/**"
  - "src/**"

# Reference examples of expected directory layout. Not enforced —
# `worktree-setup.sh create <track> <task-id> <branch>` builds the
# real path from base_path + pattern.
examples:
  - track: "track_a"
    task_id: "T-001"
    expected_path: "{{BASE_PATH}}/track_a-T-001"
  - track: "track_b"
    task_id: "T-001"
    expected_path: "{{BASE_PATH}}/track_b-T-001"
